<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.project.lam.domain.manager.mapper.ManagerMapper">

    <select id="findById" parameterType="String" resultType="com.project.lam.domain.manager.model.Manager">
        SELECT
            id,
            user_name AS userName,
            pw,
            role
        FROM lammanager.manager
        WHERE id = #{id}
    </select>

    <insert id="insert" parameterType="com.project.lam.domain.manager.model.Manager">
        INSERT INTO lammanager.manager(
            user_name AS userName,
            id,
            pw,
            role
        ) VALUES (
            #{userName},
            #{id},
            #{pw},
            #{role}
        )
    </insert>
</mapper>
